{
  "name": "echobus",
  "version": "1.0.1",
  "description": "Official client library for EchoBus — a high-performance Pub/Sub message broker with RPC and streaming",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "keywords": [
    "echobus",
    "pubsub",
    "pub-sub",
    "websocket",
    "message-broker",
    "rpc",
    "streaming",
    "real-time",
    "event-driven"
  ],
  "author": "Pallav Sharma",
  "license": "MIT-Attribution",
  "repository": {
    "type": "git",
    "url": "https://github.com/pallavsharma505/echo-bus"
  },
  "homepage": "https://github.com/pallavsharma505/echo-bus#readme",
  "bugs": {
    "url": "https://github.com/pallavsharma505/echo-bus/issues"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  }
}
